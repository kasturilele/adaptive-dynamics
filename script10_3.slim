ticks all late() {
	
	//check if any species has gone extinct
	sp1 = species1.subpopulations.individuals;      // species 1 
	sp2 = species2.subpopulations.individuals;      // species 2 
	
	// get numbers of each species
	x1 = sp1.size();
	x2 = sp2.size();
	
	if (x1 > 50000 | x2 > 50000){
		//finish simulation
		community.simulationFinished();
		
		//do the output that happens at the end of the simulation
		time_fixation_1 = MUTS1_fixed.subpopID - MUTS1_fixed.originTick;
		time_fixation_2 = MUTS2_fixed.subpopID - MUTS2_fixed.originTick;
		fixeddata = paste(rep+","+mes+","+mk_a+","+mk_b+","+"1"+","+ MUTS1_fixed.originTick + ","+time_fixation_1 + "," + MUTS1_fixed.selectionCoeff + ","+ MUTS1_fixed.mutationType.id + ","+"\n");
		writeFile(filepath + "mutdata/10_fixed_"+rep+"_"+mes+"_"+mk_a+"_"+mk_b+".csv", fixeddata, append = T);
		fixeddata = paste(rep+","+mes+","+mk_a+","+mk_b+","+"2"+","+MUTS2_fixed.originTick + ","+time_fixation_2 + "," + MUTS2_fixed.selectionCoeff + ","+ MUTS2_fixed.mutationType.id + ","+"\n");
		writeFile(filepath + "mutdata/10_fixed_"+rep+"_"+mes+"_"+mk_a+"_"+mk_b+".csv", fixeddata, append = T);
	}
	
	if (x1 < 1 | x2 < 1){
		if (community.tick < endTick - 1000){
			defineGlobal("endTick", community.tick + 1000);
		}
	}
	
	if (community.tick > endTick){
		//finish simulation
		community.simulationFinished();
		
		//do the output that happens at the end of the simulation
		time_fixation_1 = MUTS1_fixed.subpopID - MUTS1_fixed.originTick;
		time_fixation_2 = MUTS2_fixed.subpopID - MUTS2_fixed.originTick;
		fixeddata = paste(rep+","+mes+","+mk_a+","+mk_b+","+"1"+","+ MUTS1_fixed.originTick + ","+time_fixation_1 + "," + MUTS1_fixed.selectionCoeff + ","+ MUTS1_fixed.mutationType.id + ","+"\n");
		writeFile(filepath + "mutdata/10_fixed_"+rep+"_"+mes+"_"+mk_a+"_"+mk_b+".csv", fixeddata, append = T);
		fixeddata = paste(rep+","+mes+","+mk_a+","+mk_b+","+"2"+","+MUTS2_fixed.originTick + ","+time_fixation_2 + "," + MUTS2_fixed.selectionCoeff + ","+ MUTS2_fixed.mutationType.id + ","+"\n");
		writeFile(filepath + "mutdata/10_fixed_"+rep+"_"+mes+"_"+mk_a+"_"+mk_b+".csv", fixeddata, append = T);
	}
	
	// for species 1
	//	track all new fixed mutations
	muts1_temp = species1.mutations[which(species1.mutationFrequencies(p1) == 1.0)];
	muts1_new = MUTS1_fixed;
	for(m in muts1_temp){
		tf = m.subpopID;
		if(tf == 1){
			m.subpopID = community.tick;
			muts1_new = c(muts1_new, m);
		}
	}
	defineGlobal("MUTS1_fixed", muts1_new);
	
	// for species 2	
	//track all new fixed mutations
	muts2_temp = species2.mutations[which(species2.mutationFrequencies(p2) == 1.0)];
	muts2_new = MUTS2_fixed;
	for(m in muts2_temp){
		tf = m.subpopID;
		if(tf == 2){
			m.subpopID = community.tick;
			muts2_new = c(muts2_new, m);
		}
	}
	defineGlobal("MUTS2_fixed", muts2_new);

}

