ticks all first() {
	sp1 = species1.subpopulations.individuals;      // species 1 
	sp2 = species2.subpopulations.individuals;      // species 2 
	
	// non-overlapping generations: parents die, offspring live
	sp1_age = sp1.age;
	sp1[sp1_age > 0].fitnessScaling = 0.0;
	
	sp2_age = sp2.age;
	sp2[sp2_age > 0].fitnessScaling = 0.0;
	
	// get numbers of each species
	x1 = sp1.size();
	x2 = sp2.size();
	
	//r1 and r2 are birth rates, decide how many offspring generated
	//use tag to specify number of offspring
	sp1.tag = 0;
	sp2.tag = 0;
	//phenotype affects how many offspring you can have
	sp1_phenr = (sp1.sumOfMutationsOfType(m5)*mutr_1) + (sp1.sumOfMutationsOfType(m7)*mutr_1); //add effect of beneficial and deleterious mutations both
	sp2_phenr = (sp2.sumOfMutationsOfType(m1)*mutr_2) + (sp2.sumOfMutationsOfType(m3)*mutr_2);
	r1_new = r1 + sp1_phenr;
	r2_new = r2 + sp2_phenr;
	
	//sum of QTLs affects interaction coefficients
	phena11 = (sp1.sumOfMutationsOfType(m6)*muta_1) + (sp1.sumOfMutationsOfType(m8)*muta_1);
	phena22 = (sp2.sumOfMutationsOfType(m2)*muta_2) + (sp2.sumOfMutationsOfType(m4)*muta_2);
	
	//tradeoffs set caps on a11 and a12
	a11_cap = td1(r1_new);
	a22_cap = td2(r2_new);
	
	//new coefficients are old coefficient + sum of QTLs
	a11_new = pmin(a11 + phena11, a11_cap);
	a22_new = pmin(a22 + phena22, a22_cap);
	
	r1_mean = sum(r1_new)/x1;
	a11_mean = sum(a11_new)/x1;
	//catn(r1_mean +","+ a11_mean);
	r2_mean = sum(r2_new)/x2;
	a22_mean = sum(a22_new)/x2;
	//catn(r2_mean +","+ a22_mean);
	
	lambda1 = (1 + r1_new + a11_new*x1 + a12*x2);
	lambda2 = (1 + r2_new + a22_new*x2 + a21*x1);
	
	//add offspring according to poisson variable, if lambda > 0
	kids1 = sp1.tag; //set kids to 0
	kids2 = sp2.tag;
	
	valid1 = which(lambda1 > 0); //check for lambda > 0
	valid2 = which(lambda2 > 0);
	
	//only evaluate rpois for indices where lambda > 0 
	kids1[valid1] = rpois(length(lambda1[valid1]), lambda1[valid1]);
	sp1.tag = kids1;
	
	kids2[valid2] = rpois(length(lambda2[valid2]), lambda2[valid2]);
	sp2.tag = kids2;
	
	//update global variable to store r2 and a22
	defineGlobal("r1_store",r1_mean);
	defineGlobal("a11_store",a11_mean);
	defineGlobal("r2_store",r2_mean);
	defineGlobal("a22_store",a22_mean);
	
	// determine if minimum distance for population mean is close enough to ESS
	
	dist_1 = minim(r1_mean, r1e, a11_mean, a11e);
	dist_2 = minim(r2_mean, r2e, a22_mean, a22e);
	
	if(dist_1 < 0.5 & dist_2 < 0.5){
		if (community.tick < endTick - 1000){
			defineGlobal("endTick", community.tick + 1000);
		}
	}

}

