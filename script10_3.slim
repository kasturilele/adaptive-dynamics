	initializeSpecies(avatar="1", color="cornflowerblue");
	//separating beneficial and deleterious mutations
	//for r, beneficial mutations increase r
	//for alpha, beneficial mutations increase alpha numerically (make it less negative)
	//deleterious mutations:
	initializeMutationType("m5", 0.5, "g", -1, 0.5); // QTLs for r; 
	initializeMutationType("m6", 0.5, "g", -1, 0.5); // QTLs for a; 
	//beneficial mutations:
	initializeMutationType("m7", 0.5, "g", 1, 0.5); // QTLs for r; 
	initializeMutationType("m8", 0.5, "g", 1, 0.5); // QTLs for a; 
	m5.convertToSubstitution = F;
	m5.mutationStackPolicy = 'l';
	m5.color = "#FF4D2D";
	m6.convertToSubstitution = F;
	m6.mutationStackPolicy = 'l';
	m6.color = "#B15555";
	m7.convertToSubstitution = F;
