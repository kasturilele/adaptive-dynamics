// change from 7: tradeoffs are now strict, defined by fixed tradeoff function
// further change: mutations accumulate in both r and alpha, but now mutation effect bounded by tradeoff function
// change from 8: separate beneficial and deleterious mutations into two different mutation types, make deleterious mutations much more likely for r and alpha
//change from 10: save mutations for both species

//change from 10.1: not save lost mutations, no population output at intermediate timepoints, simulation ends when either one species goes extinct or both species come within 0.5 of the ESS

function (integer)sgn(float x)
{
	if (x > 0) return 1;
	if (x < 0) return -1;
	return 0;
}
function (float)avg(float x)
{
	return sum(x)/length(x);
}
function (float)td1(float b)
{
	return -0.0000206 * exp(3.2*b); //exponential tradeoff  

}
function (float)td2(float b)
{
	return -0.0000108 * exp(3.5*b); //exponential tradeoff 

}

function (float)minim(float x, float px, float y, float py)
{
	return sqrt((x - px)*(x - px)/0.01 + (y - py)*(y - py)/1e-10);
}

species all initialize() {
	//code that reads params from file
	params = readCSV("../params/pairparams_new.csv");
	mutkern = readCSV("../params/pairparams_mk_new.csv"); //mutation kernel
	if (exists("slimgui"))
	{
		defineConstant("rep", 1);
		defineConstant("mes", 4);
		defineConstant("mk_a", 15);
	    defineConstant("mk_b", 15);
		
	}
	defineConstant("filepath", "/cluster/tufts/uricchiolab/klele01/slimcode/outputs_tradeoffs/outputs_01_02/"); //file path for outputs

    //toy parameters
	defineConstant("N0_1",params.getValue("N10")[rep]); //initial pop size
	defineConstant("N0_2",params.getValue("N20")[rep]); //initial pop size
	defineConstant("r1",params.getValue("r1")[rep]); //growth rate
	defineConstant("r2",params.getValue("r2")[rep]); //growth rate
	defineConstant("a11",params.getValue("a11")[rep]);; //interaction coefficient
	defineConstant("a22",params.getValue("a22")[rep]);; //interaction coefficient
	defineConstant("a12", params.getValue("a12")[rep]);; //interaction coefficient
	defineConstant("a21", params.getValue("a21")[rep]);; //interaction coefficient
	
	//read proportion of beneficial vs deleterious mutations
	defineConstant("mk1",mutkern.getValue("m1")[mk_a]); //for s1
	defineConstant("mk2",mutkern.getValue("m2")[mk_a]); //for s1
	defineConstant("mk3",mutkern.getValue("m3")[mk_a]); //for s1
	defineConstant("mk4",mutkern.getValue("m4")[mk_a]); //for s1
	
	defineConstant("mk5",mutkern.getValue("m1")[mk_b]); //for s2
	defineConstant("mk6",mutkern.getValue("m2")[mk_b]); //for s2
	defineConstant("mk7",mutkern.getValue("m3")[mk_b]); //for s2
	defineConstant("mk8",mutkern.getValue("m4")[mk_b]); //for s2
	
	//mutation rate determined from file
	defineConstant("mut_1", mutkern.getValue("mut")[mk_a]); //mutation rate for species 1
	defineConstant("mut_2", mutkern.getValue("mut")[mk_b]); //mutation rate for species 2
	
	//defining mutation effect multipliers here - species 1
	defineConstant("mutr_1", mutkern.getValue("mutr")[mk_a]);
	defineConstant("muta_1", mutkern.getValue("muta")[mk_a]);
	
	//defining mutation effect multipliers here - species 2
	defineConstant("mutr_2", mutkern.getValue("mutr")[mk_b]);
	defineConstant("muta_2", mutkern.getValue("muta")[mk_b]);
	
	//use value of mutation kernal from file to write in file name
	defineConstant("mk_fw1", mutkern.getValue("mutation_kernel")[mk_a]);
	defineConstant("mk_fw2", mutkern.getValue("mutation_kernel")[mk_b]);
	
	//define Global variable to store mean r2 and a22 values
	defineGlobal("r1_store",r1);
	defineGlobal("a11_store",a11);
	defineGlobal("r2_store",r2);
	defineGlobal("a22_store",a22);
	
	//define ESS values of r1, r2, a11, a22
	defineConstant("r1e", 0.498344);
	defineConstant("r2e", 0.362690);
	defineConstant("a11e", -0.0001015);
	defineConstant("a22e", -0.0000384);
	
	defineConstant("dt", 1);
	defineConstant("lt", 100); //log time - so that same ticks get printed on screen and in the log file
	defineGlobal("endTick", 1000002); //variable that keeps track of whether simulation needs to end, set it to value of end tick
	
	initializeSLiMModelType("nonWF");
	
	defineConstant("S1", "S1"); //get strain names to store in file
	defineConstant("S2", "S2");
}
