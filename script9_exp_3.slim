	if (x2 > 500){
	inds = p2.sampleIndividuals(500);
	}
	else {
	inds = sp2;
	}
	r2_new = r2 + (inds.sumOfMutationsOfType(m1) * mutr) + (inds.sumOfMutationsOfType(m3) * mutr); //add effect of beneficial and deleterious mutations both
	a22_temp = a22 + (inds.sumOfMutationsOfType(m2) * muta) + (inds.sumOfMutationsOfType(m4) * muta); //add effect of beneficial and deleterious mutations both
	a22_cap = tradeoff(r2_new); //tradeoff decides upper bound of phenotype
	a22_new = pmin(a22_temp, a22_cap); //mutations decreasing alpha have no effect if alpha goes below tradeoff; using pmin because of sign change
	tp = community.tick;
	output = "rep,mes,mk,IDs,r2,a22,m1,m2,m3,m4,time\n";
	i = 0;
	for (ind in inds){
	id_str = "i" + asString(ind.index);
	output = output + rep + "," + mes + "," + mk + "," + id_str+","+r2_new[i]+","+a22_new[i]+"," +ind.countOfMutationsOfType(m1)+","+ ind.countOfMutationsOfType(m2)+","+ ind.countOfMutationsOfType(m3)+","+ ind.countOfMutationsOfType(m4)+","+ tp + "\n";
	i = i + 1;
	}
	writeFile(filepath + "logfiles/outpop_2000_" + rep + "_" + mes +"_" + mk + ".csv", output);
	
	//output properties of mutations segregating in population
	mutstemp = species2.mutations;
	mutsdata = "rep,mes,mk,type,origin,effect_size,frequency,time\n";
	mutsdata = mutsdata + paste(rep + "," + mes + "," + mk + "," + mutstemp.mutationType.id + "," + mutstemp.originTick + "," + mutstemp.selectionCoeff + "," + species2.mutationFrequencies(p2) + "," + tp +"\n");
		writeFile(filepath + "mutdata/outmut_2000_" + rep + "_" + mes + ".csv", mutsdata);
	
}

