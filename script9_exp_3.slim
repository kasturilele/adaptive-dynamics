// change from 7: tradeoffs are now strict, defined by fixed tradeoff function
// further change: mutations accumulate in both r and alpha, but now mutation effect bounded by tradeoff function
// change from 8: separate beneficial and deleterious mutations into two different mutation types, make deleterious mutations much more likely for r and alpha
function (integer)sgn(float x)
{
	if (x > 0)
		return 1;
	if (x < 0)
		return -1;
	return 0;
}

function (float)avg(float x)
{
	return sum(x) / length(x);
}

function (float)tradeoff(float b)
{
	 return -0.0000206 * exp(3.2*b); //exponential tradeoff 
	
}

species all initialize()
{
	//code that reads params from file
	params = readCSV("../params/single_params_3.csv");
	mutkern = readCSV("../params/mutation_kernel_extra.csv"); //mutation kernel
	defineConstant("filepath", "/cluster/tufts/uricchiolab/klele01/slimcode/outputs_tradeoffs/outputs_11_16_3/"); //file path for outputs
	if (exists("slimgui"))
	{
		defineConstant("rep", 0);
		defineConstant("mes", 0);
		defineConstant("mk", 5);
	}
	
	//toy parameters
	defineConstant("N0_y", params.getValue("N10")[rep]); //initial pop size
	defineConstant("r2", params.getValue("r1")[rep]); //growth rate
	defineConstant("a22", params.getValue("a11")[rep]); //interaction coefficient

	//parameters controlling supply of mutations: read from file
	//read proportion of beneficial vs deleterious mutations
	defineConstant("mk1", mutkern.getValue("m1")[mk]); //for m1
	defineConstant("mk2", mutkern.getValue("m2")[mk]); //for m1
	defineConstant("mk3", mutkern.getValue("m3")[mk]); //for m1
	defineConstant("mk4", mutkern.getValue("m4")[mk]); //for m1
	
	//
	defineConstant("mut", mutkern.getValue("mut")[mk]); //mutation rate
	
	//defining mutation effect multipliers here
	defineConstant("mutr", mutkern.getValue("mutr")[mk]);
	defineConstant("muta", mutkern.getValue("muta")[mk]);
	
	//define Global variable to store mean r2 and a22 values
	defineGlobal("r2_store", r2);
	defineGlobal("a22_store", a22);
	defineConstant("dt", 1);
	defineConstant("lt", 100); //log time - so that same ticks get printed on screen and in the log file
	initializeSLiMModelType("nonWF");
	

}

species species2 initialize()
{
	initializeSpecies(avatar="2", color="red");
	
	//separating beneficial and deleterious mutations
	//for r, beneficial mutations increase r
	//for alpha, beneficial mutations increase alpha numerically (make it less negative)
	//deleterious mutations:
	initializeMutationType("m1", 0.5, "g", -1, 0.5); // QTLs for r; 
	initializeMutationType("m2", 0.5, "g", -1, 0.5); // QTLs for a; 
	
	//beneficial mutations:
	initializeMutationType("m3", 0.5, "g", 1, 0.5); // QTLs for r; 
	initializeMutationType("m4", 0.5, "g", 1, 0.5); // QTLs for a; 
	m1.convertToSubstitution = F;
	m1.mutationStackPolicy = 'l';
	m1.color = "#FF4D2D";
	m2.convertToSubstitution = F;
	m2.mutationStackPolicy = 'l';
	m2.color = "#B15555";
	m3.convertToSubstitution = F;
	m3.mutationStackPolicy = 'l';
	m3.color = "#41FDD6";
	m4.convertToSubstitution = F;
	m4.mutationStackPolicy = 'l';
	m4.color = "#01AB8E";
	initializeGenomicElementType("g1", c(m1, m2, m3, m4), c(mk1, mk2, mk3, mk4));
	initializeGenomicElement(g1, 0, 999);
	initializeRecombinationRate(0.5);
	initializeMutationRate(mut);
}

