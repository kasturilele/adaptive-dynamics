ticks all 1 early()
{
	species2.addSubpop("p2", asInteger(N0_y), haploid=T);
	defineGlobal("MUTS", species2.mutations); // will be empty at this point
	defineGlobal("MUTS_fixed", species2.mutations[which(species2.mutationFrequencies(p2) == 1.0)]); // will be empty at this point
	
	//delete old file for logging mutation data (if it exists)
	deleteFile(filepath + "logfiles/output_" + rep + "_" + mes +"_" + mk + ".csv");
	deleteFile(filepath + "mutdata/fixed_" + rep + "_" + mes +"_" + mk + ".csv");
	deleteFile(filepath + "mutdata/lost_" + rep + "_" + mes +"_" + mk + ".csv");
	
	//create new file for logging mutation data
	writeFile(filepath + "mutdata/lost_" + rep + "_" + mes +"_" + mk + ".csv", paste("rep" + "," + "mes" + "," + "time_loss" + "," + "effect_size" + "," + "mutation_type" + "," + "blank" + "," + "blank"));
}

// ************************************************ 
// ******************** FIRST ********************* 
// ************************************************
ticks all first()
{
	sp2 = species2.subpopulations.individuals; // species 2 
	
	// non-overlapping generations: parents die, offspring live
	sp2_age = sp2.age;
	sp2[sp2_age > 0].fitnessScaling = 0.0;
	
	// get numbers of each species
	x2 = sp2.size();
	
	//r1 and r2 are birth rates, decide how many offspring generated
	//use tag to specify number of offspring
	sp2.tag = 0;
	
	//mutation effects under covariance for species 2
	r2_mean = 0;
	a22_mean = 0;
	r2_new = r2 + (sp2.sumOfMutationsOfType(m1) * mutr) + (sp2.sumOfMutationsOfType(m3) * mutr); //add effect of beneficial and deleterious mutations both
	a22_temp = a22 + (sp2.sumOfMutationsOfType(m2) * muta) + (sp2.sumOfMutationsOfType(m4) * muta); //add effect of beneficial and deleterious mutations both
	a22_cap = tradeoff(r2_new); //tradeoff decides upper bound of phenotype
	a22_new = pmin(a22_temp, a22_cap); //mutations decreasing alpha have no effect if alpha goes below tradeoff; using pmin because of sign change
	r2_mean = sum(r2_new) / x2;
	a22_mean = sum(a22_new) / x2;
	
	//catn(r2_mean +","+ a22_mean);
	lambda = 1 + r2_new + a22_new * x2;
	
	//catn(min(r2_new) + " ,"+ max(a22_new)+" ,"+ min(lambda));
	//add offspring according to poisson variable, if lambda > 0
	kids2 = sp2.tag; //set kids to 0
	
	//check for lambda > 0
	valid2 = which(lambda > 0);
	
	//only evaluate rpois for indices where lambda > 0 
	kids2[valid2] = rpois(length(lambda[valid2]), lambda[valid2]);
	sp2.tag = kids2;
	
	//update global variable to store r2 and a22
	defineGlobal("r2_store", r2_mean);
	defineGlobal("a22_store", a22_mean);
}

