ticks all 2 late()
{
	//setting up a log file
	logfile = community.createLogFile(filepath + "logfiles/output_" + rep + "_" + mes +"_" + mk + ".csv", logInterval=lt);
	logfile.addTick();
	logfile.addPopulationSize(species2);
	logfile.addCustomColumn("r2", "r2_store;");
	logfile.addCustomColumn("a22", "a22_store;");
}

ticks all late()
{
	//check if any species has gone extinct
	sp2 = species2.subpopulations.individuals; // species 2 
	
	// get numbers of each species
	x2 = sp2.size();
	if (x2 < 1)
	{
		community.simulationFinished();
	}
	if (x2 > 20000)
	{
		//finish simulation
		community.simulationFinished();
	}
	
	// find all mutations that are no longer segregating
	is_seg = MUTS.isSegregating;
	muts_nonseg = MUTS[!is_seg];
	
	//catn(MUTS.selectionCoeff);
	// tabulate lifetimes for those that have been lost (not fixed)
	muts_lost = muts_nonseg[!muts_nonseg.isFixed];
	lost_lifetimes = community.tick - muts_lost.originTick;
	
	//catn(community.tick + ", mutations lost: " + size(muts_lost));
	//catn("nonsegragating: " + size(muts_nonseg)+", lost: "+ size(!muts_nonseg.isFixed));
	//catn("lost: " + muts_lost.selectionCoeff);
	if (size(muts_lost) > 0)
	{
		lostdata = paste(rep + "," + mes + "," + mk + "," + lost_lifetimes + "," + muts_lost.selectionCoeff + "," + muts_lost.mutationType.id + "," + "\n");
		writeFile(filepath + "mutdata/lost_" + rep + "_" + mes +"_" + mk + ".csv", lostdata, append=T);
		
		//cat(lostdata);
	}
	
	// track all newly generated mutations
	// also, narrow down our tracking to those mutations still segregating
	new_muts = species2.mutations;
	new_muts = new_muts[new_muts.originTick == community.tick];
	defineGlobal("MUTS", c(MUTS[is_seg], new_muts));
	
	//track all new fixed mutations 
	defineGlobal("MUTS_fixed", species2.mutations[which(species2.mutationFrequencies(p2) == 1.0)]);
	for (m in MUTS_fixed)
	{
		tf = m.subpopID;
		if (tf == 2)
		{
			m.subpopID = community.tick;
		}
	}
	
	//catn(community.tick+","+MUTS_fixed.subpopID);
}

