species species2 reproduction()
{
	litterSize2 = individual.tag;
	if (litterSize2 > 0)
	{
		//changing reproduction to add selfing
		for (i in seqLen(litterSize2))
			subpop.addRecombinant(individual.genome1, NULL, NULL, NULL, NULL, NULL);
	}
}

